{
	"image": "node:latest",
	"customizations": {
		"vscode": {
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				"eslint.validate": [
					"javascript",
					"javascriptreact",
					"typescript",
					"typescriptreact",
					"svelte"
				],
				"svelte.plugin.svelte.enable-ts-plugin": true
			},
			"extensions": ["svelte.svelte-vscode", "esbenp.prettier-vscode", "dbaeumer.vscode-eslint"]
		}
	},
	"forwardPorts": [5173]
}
